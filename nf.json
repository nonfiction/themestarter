{
  "version": 1,
  "project": {
    "password_version": 0,
    "slug": "themestarter",
    "type": "wordpress-theme"
  },
  "wordpress": {
    "deploy_unit": "theme",
    "plugins": [
      "imsanity",
      "insert-headers-and-footers",
      "query-monitor",
      "stream",
      "wp-crontrol",
      "wp-test-email",
      {
        "slug": "agency-credit",
        "source": "repo"
      }
    ],
    "theme_path": "theme",
    "theme_slug": "themestarter"
  },
  "env": {
    "compose": "docker compose",
    "theme_mount_slug": "theme",
    "uploads_path": "uploads",
    "wordpress_service": "wordpress"
  },
  "artifact": {
    "path": "dist/themestarter-v{version}.zip"
  },
  "remotes": {},
  "tasks": {
    "build": {
      "description": "Build the theme assets",
      "run": "npm --prefix theme run build"
    },
    "composer": {
      "description": "Update theme Composer dependencies",
      "run": "composer --working-dir=theme update \u0026\u0026 composer --working-dir=theme dump-autoload -o"
    },
    "npm": {
      "description": "Refresh theme development dependencies",
      "run": "npm --prefix theme update --save-dev"
    },
    "seed": {
      "description": "Seed starter WordPress content",
      "run": "scripts/seed-starter-content"
    },
    "test": {
      "description": "Run all theme checks",
      "run": "nf theme lint"
    },
    "watch": {
      "description": "Watch theme assets during development",
      "run": "npm --prefix theme start"
    }
  }
}
