{
  "version": 1,
  "project": {
    "slug": "theme-starter",
    "type": "wordpress-theme"
  },
  "wordpress": {
    "deploy_unit": "theme",
    "plugins": [
      "stream",
      "wp-crontrol",
      "insert-headers-and-footers",
      "block-visibility"
    ],
    "theme_path": "theme",
    "theme_slug": "theme-starter"
  },
  "env": {
    "cli_service": "cli",
    "compose": "docker compose",
    "theme_mount_slug": "theme",
    "uploads_path": "uploads",
    "wordpress_service": "wordpress"
  },
  "artifact": {
    "path": "dist/theme-starter-v{version}.zip"
  },
  "remotes": {},
  "tasks": {
    "build": {
      "description": "Build the theme assets",
      "run": "npm --prefix theme run build"
    },
    "composer": {
      "description": "Update theme Composer dependencies",
      "run": "composer --working-dir=theme update \u0026\u0026 composer --working-dir=theme dump-autoload -o"
    },
    "format": {
      "description": "Format authored PHP files",
      "run": "composer --working-dir=theme format:php"
    },
    "lint": {
      "description": "Run PHP and JavaScript checks",
      "run": "composer --working-dir=theme test \u0026\u0026 npm --prefix theme run lint"
    },
    "npm": {
      "description": "Refresh theme development dependencies",
      "run": "npm --prefix theme update --save-dev"
    },
    "release": {
      "description": "Build, test, and package the theme artifact",
      "run": "nf theme build \u0026\u0026 nf theme lint \u0026\u0026 nf theme package"
    },
    "test": {
      "description": "Run all theme checks",
      "run": "nf theme lint"
    },
    "watch": {
      "description": "Watch theme assets during development",
      "run": "npm --prefix theme start"
    }
  }
}
