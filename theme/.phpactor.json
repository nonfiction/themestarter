{
  "indexer.stub_paths": [
    "%project_root%/vendor/php-stubs/wordpress-stubs"
  ],
  "code_transform.indentation": "  ",
  "language_server_php_cs_fixer.enabled": true,
  "language_server_php_cs_fixer.config": "%project_root%/.php-cs-fixer.dist.php",
  "language_server.diagnostic_ignore_codes": [
    "worse.missing_return_type",
    "worse.docblock_missing_return_type",
    "worse.docblock_missing_param"
  ],
  "php_code_sniffer.enabled": false
}
