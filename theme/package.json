{
  "name": "nonfiction-theme-starter",
  "version": "0.0.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git://github.com/nonfiction/theme-starter.git"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not op_mini all"
  ],
  "stylelint": {
    "plugins": [
      "stylelint-no-unsupported-browser-features"
    ],
    "rules": {
      "plugin/no-unsupported-browser-features": true
    },
    "defaultSeverity": "warning"
  },
  "scripts": {
    "build": "vite build",
    "lint": "eslint app config vite.config.js",
    "start": "vite build --watch"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "devDependencies": {
    "@zackad/prettier-plugin-twig": "^0.17.0",
    "bootstrap-reboot": "^4.5.6",
    "classnames": "^2.2.6",
    "eslint": "^10.4.1",
    "eslint-plugin-compat": "^7.0.2",
    "hamburgers": "^1.1.3",
    "jquery": "^3.6.0",
    "postcss": "^8.0.9",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.0",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.8.3",
    "slick-carousel": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-no-unsupported-browser-features": "^4.0.0",
    "vite": "^7.1.3"
  }
}
