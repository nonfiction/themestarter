{
  "name": "nonfiction-theme-starter",
  "version": "0.0.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git://github.com/nonfiction/theme-starter.git"
  },
  "browserslist": [
    ">1%",
    "last 4 versions",
    "android 4",
    "opera 12",
    "not ie < 11"
  ],
  "eslintConfig": {
    "parserOptions": {
      "ecmaVersion": 6
    },
    "plugins": [
      "compat"
    ],
    "rules": {
      "compat/compat": "warn"
    }
  },
  "stylelint": {
    "plugins": [
      "stylelint-no-unsupported-browser-features"
    ],
    "rules": {
      "plugin/no-unsupported-browser-features": true
    },
    "defaultSeverity": "warning"
  },
  "scripts": {
    "build": "vite build",
    "start": "vite build --watch"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "devDependencies": {
    "@iconfu/svg-inject": "^1.2.3",
    "@terwanerik/scrolltrigger": "^1.0.5",
    "aos": "^2.3.4",
    "bootstrap-reboot": "^4.5.6",
    "classnames": "^2.2.6",
    "eslint": "^7.29.0",
    "eslint-plugin-compat": "^3.8.0",
    "flatpickr": "^4.6.9",
    "hamburgers": "^1.1.3",
    "jquery": "^3.6.0",
    "jquery-dropdown-datepicker": "^1.3.0",
    "js-cookie": "^3.0.1",
    "load-google-maps-api": "^2.0.2",
    "macy": "^2.5.1",
    "moment": "^2.29.1",
    "moment-range": "^4.0.2",
    "normalize.css": "^8.0.1",
    "postcss": "^8.0.9",
    "postcss-import": "^12.0.1",
    "postcss-preset-env": "^6.7.0",
    "postcss-pxtorem": "^5.1.1",
    "slick-carousel": "^1.8.1",
    "stylelint": "^13.7.1",
    "stylelint-no-unsupported-browser-features": "^4.0.0",
    "uuid": "^3.4.0",
    "vite": "^7.1.3"
  },
  "optionalDependencies": {
    "fsevents": "^2.1.3"
  }
}
