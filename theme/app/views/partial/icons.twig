{% macro search(class = '') %}
  <svg
    class="{{ class|default('') }}"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 16.706 16.706"
    aria-hidden="true"
    focusable="false"
  >
    <g transform="translate(91.756 -456.762)">
      <circle
        cx="6.03"
        cy="6.03"
        r="6.03"
        transform="translate(-90.756 457.762)"
        fill="none"
        stroke="currentColor"
        stroke-miterlimit="10"
        stroke-width="2"
      />
      <line
        x2="4.528"
        y2="4.528"
        transform="translate(-80.461 468.057)"
        fill="none"
        stroke="currentColor"
        stroke-miterlimit="10"
        stroke-width="2.5"
      />
    </g>
  </svg>
{% endmacro %}

{% macro arrow_left(class = '') %}
  <svg
    class="{{ class|default('') }}"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M14 5 8 12l6 7"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2.5"
    />
  </svg>
{% endmacro %}

{% macro arrow_right(class = '') %}
  <svg
    class="{{ class|default('') }}"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M10 5l6 7-6 7"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2.5"
    />
  </svg>
{% endmacro %}

{% macro social(title, link, class = '') %}
  {% set title_key =
    title
      |default('')
      |lower
      |replace({
        ' ': '',
        '-': '',
        '_': ''
      })
  %}
  {% set link_key = link|default('')|lower %}
  {% set icon = 'facebook' %}

  {% if 'linkedin' in title_key or 'linkedin.com' in link_key %}
    {% set icon = 'linkedin' %}
  {% elseif 'instagram' in title_key or 'instagram.com' in link_key %}
    {% set icon = 'instagram' %}
  {% elseif
    'twitter' in title_key
      or 'x.com' in link_key
      or 'twitter.com' in link_key %}
    {% set icon = 'twitter' %}
  {% endif %}

  <svg
    class="{{ class|default('') ? class ~ ' icon-' ~ icon : 'icon-' ~ icon }}"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    focusable="false"
  >
    {% if icon == 'linkedin' %}
      <path
        d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"
        fill="currentColor"
      />
    {% elseif icon == 'instagram' %}
      <path
        d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.668.072 4.948c.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072s3.668-.014 4.948-.072c4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
        fill="currentColor"
      />
    {% elseif icon == 'twitter' %}
      <path
        d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.58-6.646 7.58H.468l8.617-9.84L0 1.154h7.594l5.243 6.932 6.064-6.933Zm-1.296 19.09h2.04L6.49 3.247H4.303l13.303 16.996Z"
        fill="currentColor"
      />
    {% else %}
      <path
        d="M9 8H6v4h3v12h5V12h3.642L18 8h-4V6.333c0-.955.192-1.333 1.115-1.333H18V0h-3.808C10.596 0 9 1.583 9 4.615V8z"
        fill="currentColor"
      />
    {% endif %}
  </svg>
{% endmacro %}
