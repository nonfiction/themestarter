<article class="tease tease-{{ post.post_type }}" id="tease-{{ post.ID }}">
  {% block content %}
    <h2 class="tease__title"><a href="{{ post.link }}">{{ post.title }}</a></h2>
    {% if post.preview %}
      <p>{{ post.preview }}</p>
    {% endif %}
    {% if post.get_thumbnail %}
      <img src="{{ post.thumbnail.src }}" alt="">
    {% endif %}
  {% endblock %}
</article>
