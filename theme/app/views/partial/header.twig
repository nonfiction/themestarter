<header id="header">
  <div class="container site-header__inner">
    <a class="site-logo" href="{{ site.link }}" aria-label="{{ site.title }} home">
      <span class="site-logo__mark" aria-hidden="true">{{ site.title|slice(0, 1) }}</span>
      <span class="site-logo__text">{{ site.title }}</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {% include 'partial/menu.twig' with {
        items: menu_primary ? menu_primary.get_items : [],
        list_class: 'main-nav',
        child_class: 'subnav'
      } only %}
    </nav>
    <div class="site-search">
      <form action="{{ site.link }}/" class="search-form" method="get">
        <label class="screen-reader-text" for="site-search-field">Search</label>
        <input id="site-search-field" name="s" type="search" placeholder="Search" value="{{ s }}">
        <button type="submit" class="search-btn">Search</button>
      </form>
    </div>
  </div>
</header>
